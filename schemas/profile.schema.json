{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aim.dev/schemas/profile.schema.json",
  "title": "Environment Profile",
  "description": "Schema for environment profiles in AutoInstallManager",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "tools"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version for compatibility tracking",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "id": {
      "type": "string",
      "description": "Unique identifier for the profile",
      "pattern": "^[a-z0-9-]+$",
      "examples": ["web-tauri", "cpp-toolchain"]
    },
    "name": {
      "type": "string",
      "description": "Display name of the profile",
      "minLength": 1,
      "examples": ["Web + Tauri", "C++ Toolchain"]
    },
    "description": {
      "type": "string",
      "description": "Brief description of the profile"
    },
    "tools": {
      "type": "array",
      "description": "Tools included in this profile",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Tool ID from catalog"
          },
          "version": {
            "type": "string",
            "description": "Specific version or version constraint"
          },
          "versionStrategy": {
            "type": "string",
            "enum": ["exact", "minor", "major", "latest", "lts"],
            "default": "exact",
            "description": "Version selection strategy"
          },
          "optional": {
            "type": "boolean",
            "default": false,
            "description": "Whether this tool is optional"
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "description": "Environment configuration",
      "properties": {
        "addToPath": {
          "type": "boolean",
          "default": true,
          "description": "Whether to add tools to PATH"
        },
        "variables": {
          "type": "object",
          "description": "Additional environment variables",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "author": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
